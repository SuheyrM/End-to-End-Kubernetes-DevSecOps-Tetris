pipeline {
  agent {
    kubernetes {
      yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: tools
    image: docker:27.3-cli
    command: ["cat"]
    tty: true
    env:
      - name: DOCKER_HOST
        value: tcp://localhost:2375
  - name: dind
    image: docker:27.3-dind
    securityContext:
      privileged: true
    env:
      - name: DOCKER_TLS_CERTDIR
        value: ""
    ports:
      - containerPort: 2375
"""
      defaultContainer 'tools'
    }
  }

  environment {
    AWS_REGION   = "us-east-1"
    ECR_REGISTRY = "972598852792.dkr.ecr.us-east-1.amazonaws.com"
    ECR_REPO     = "tetris-app"
    IMAGE_TAG    = "${env.BUILD_NUMBER}"
    IMAGE_URI    = "${ECR_REGISTRY}/${ECR_REPO}:${IMAGE_TAG}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install tools (awscli + trivy + kubectl)') {
      steps {
        sh '''
          set -eux

          apk add --no-cache aws-cli curl tar kubectl

          # Install Trivy binary
          TRIVY_VERSION="0.69.3"
          curl -sSL -o /tmp/trivy.tar.gz https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VERSION}/trivy_${TRIVY_VERSION}_Linux-64bit.tar.gz
          tar -xzf /tmp/trivy.tar.gz -C /usr/local/bin trivy

          aws --version
          kubectl version --client
          trivy --version
        '''
      }
    }

    stage('Wait for Docker daemon') {
      steps {
        sh '''
          set -eux
          for i in $(seq 1 30); do
            if docker info >/dev/null 2>&1; then
              echo "Docker daemon is ready"
              exit 0
            fi
            echo "Waiting for Docker daemon... ($i/30)"
            sleep 2
          done
          echo "Docker daemon never became ready"
          docker version || true
          exit 1
        '''
      }
    }

    stage('Build Docker image') {
      steps {
        sh '''
          set -eux
          docker build -t tetris-app:ci .
        '''
      }
    }

    stage('Trivy scan (fail on CRITICAL)') {
      steps {
        sh '''
          set -eux
          trivy image --exit-code 1 --severity CRITICAL tetris-app:ci
          trivy image --severity HIGH,CRITICAL tetris-app:ci
        '''
      }
    }

    stage('Login to ECR + Push') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws-ecr-credentials', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          sh '''
            set -eux

            aws ecr get-login-password --region ${AWS_REGION} \
              | docker login --username AWS --password-stdin ${ECR_REGISTRY}

            docker tag tetris-app:ci ${IMAGE_URI}
            docker push ${IMAGE_URI}

            docker tag tetris-app:ci ${ECR_REGISTRY}/${ECR_REPO}:latest
            docker push ${ECR_REGISTRY}/${ECR_REPO}:latest
          '''
        }
      }
    }

    stage('Deploy to EKS') {
      steps {
        withCredentials([file(credentialsId: 'eks-kubeconfig', variable: 'KUBECONFIG')]) {
          sh '''
            set -eux

            kubectl get deploy tetris
            kubectl set image deployment/tetris tetris=${IMAGE_URI}
            kubectl rollout status deployment/tetris --timeout=180s
          '''
        }
      }
    }
  }

  post {
    always {
      sh '''
        docker images | head -n 30 || true
      '''
    }
  }
}
